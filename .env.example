# Client: Supabase project URL. Find it in Supabase Project Settings > API.
VITE_SUPABASE_URL=

# Client: Supabase anon key. Safe for browser use when RLS is enabled.
VITE_SUPABASE_ANON_KEY=

# Client: Backend API base URL for REST calls.
VITE_API_URL=http://localhost:5000

# Client: Paystack public key for any future inline checkout/verification UX.
VITE_PAYSTACK_PUBLIC_KEY=

# Server: Supabase project URL. Same project as VITE_SUPABASE_URL.
SUPABASE_URL=

# Server: Supabase service role key. Keep secret; bypasses RLS for trusted API operations.
SUPABASE_SERVICE_KEY=

# Server: Backward-compatible alias if an older deploy uses this name.
SUPABASE_SERVICE_ROLE_KEY=

# Server: Paystack secret key used to resolve Nigerian bank accounts and later transfers.
PAYSTACK_SECRET_KEY=

# Server: Reserved for custom JWT signing if needed; Supabase JWT verification is used now.
JWT_SECRET=

# Server: Gmail address for Nodemailer SMTP email notifications.
GMAIL_USER=

# Server: Gmail app password for Nodemailer SMTP email notifications.
GMAIL_PASS=

# Server: Exact frontend origin allowed by CORS.
FRONTEND_URL=http://localhost:5173

# Server: API port.
PORT=5000

# Server: development or production.
NODE_ENV=development
